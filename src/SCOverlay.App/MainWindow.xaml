<Window x:Class="SCOverlay.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SC Overlay"
        MinHeight="360"
        MinWidth="640"
        Height="420"
        Width="900"
        Background="#101418">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="SC Overlay"
                       Foreground="#F2F6FA"
                       FontSize="30"
                       FontWeight="SemiBold" />
            <TextBlock Text="Phase 3 input diagnostics"
                       Foreground="#AAB7C4"
                       FontSize="15"
                       Margin="0,6,0,0" />
        </StackPanel>

        <Border Grid.Row="2"
                BorderBrush="#2A3440"
                BorderThickness="1"
                Background="#161D24"
                CornerRadius="6"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Input diagnostics"
                           Foreground="#F2F6FA"
                           FontSize="18"
                           FontWeight="SemiBold" />

                <TextBlock Grid.Row="1"
                           x:Name="StatusText"
                           Foreground="#D5E1EA"
                           FontSize="14"
                           Margin="0,14,0,0"
                           TextWrapping="Wrap" />

                <TextBlock Grid.Row="2"
                           x:Name="DataRootText"
                           Foreground="#9FB0BE"
                           FontSize="13"
                           Margin="0,12,0,0"
                           TextWrapping="Wrap" />

                <Grid Grid.Row="3" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Devices"
                                   Foreground="#F2F6FA"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="DevicesText"
                                   Foreground="#D5E1EA"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Capture"
                                   Foreground="#F2F6FA"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button x:Name="CaptureButton"
                                    Content="Capture KBM Binding"
                                    MinWidth="150"
                                    Height="30"
                                    Click="CaptureButton_OnClick" />
                            <TextBlock x:Name="CaptureText"
                                       Foreground="#D5E1EA"
                                       FontSize="12"
                                       Margin="12,6,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="4" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border BorderBrush="#26313C"
                            BorderThickness="1"
                            Background="#111820"
                            CornerRadius="4"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="Raw snapshot"
                                       Foreground="#F2F6FA"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="RawSnapshotText"
                                       Foreground="#D5E1EA"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            BorderBrush="#26313C"
                            BorderThickness="1"
                            Background="#111820"
                            CornerRadius="4"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="Profile values"
                                       Foreground="#F2F6FA"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="ProfileValuesText"
                                       Foreground="#D5E1EA"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
