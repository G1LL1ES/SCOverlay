<Window x:Class="SCOverlay.App.DesktopOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="SC Overlay Desktop Overlay"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Width="900"
        Height="520">
    <Grid x:Name="Root"
          Background="Transparent"
          MouseLeftButtonDown="Root_OnMouseLeftButtonDown">
        <Canvas x:Name="OverlayCanvas"
                IsHitTestVisible="False" />

        <Border x:Name="EditFrame"
                BorderBrush="#66D5E1EA"
                BorderThickness="1"
                Background="#11000000"
                Visibility="Collapsed" />

        <Border x:Name="Toolbar"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="8"
                Padding="8,5"
                Background="#DD101820"
                BorderBrush="#556B7C8B"
                BorderThickness="1"
                CornerRadius="4"
                Visibility="Collapsed">
            <TextBlock x:Name="ToolbarText"
                       Foreground="#F2F6FA"
                       FontSize="12"
                       FontWeight="SemiBold" />
        </Border>

        <primitives:Thumb x:Name="ResizeThumb"
                          Width="18"
                          Height="18"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Margin="0,0,3,3"
                          Cursor="SizeNWSE"
                          DragDelta="ResizeThumb_OnDragDelta"
                          Visibility="Collapsed">
            <primitives:Thumb.Template>
                <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                    <Border Background="#AA26313C"
                            BorderBrush="#99D5E1EA"
                            BorderThickness="1"
                            CornerRadius="2" />
                </ControlTemplate>
            </primitives:Thumb.Template>
        </primitives:Thumb>
    </Grid>
</Window>
