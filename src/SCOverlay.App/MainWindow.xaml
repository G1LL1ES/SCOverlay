<Window x:Class="SCOverlay.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SC Overlay"
        MinHeight="560"
        MinWidth="900"
        Height="720"
        Width="1180"
        Background="#101418">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="SC Overlay"
                           Foreground="#F2F6FA"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="HeaderText"
                           Foreground="#AAB7C4"
                           FontSize="14"
                           Margin="0,5,0,0"
                           TextWrapping="Wrap" />
            </StackPanel>

            <TextBlock Grid.Column="1"
                       x:Name="ObsUrlText"
                       Foreground="#C7D6E2"
                       FontSize="12"
                       Margin="24,8,0,0"
                       TextAlignment="Right"
                       TextWrapping="Wrap" />
        </Grid>

        <TabControl Grid.Row="2"
                    Background="#161D24"
                    BorderBrush="#2A3440"
                    Foreground="#F2F6FA">
            <TabItem Header="Setup">
                <Grid Margin="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border BorderBrush="#26313C"
                            BorderThickness="1"
                            Background="#111820"
                            CornerRadius="4"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Profiles"
                                       Foreground="#F2F6FA"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Active profile"
                                       Foreground="#9FB0BE"
                                       FontSize="12"
                                       Margin="0,14,0,5" />
                            <ComboBox x:Name="ProfileComboBox"
                                      MinHeight="30"
                                      DisplayMemberPath="Name"
                                      SelectionChanged="ProfileComboBox_OnSelectionChanged" />

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="NewProfileNameTextBox"
                                         MinHeight="30"
                                         VerticalContentAlignment="Center" />
                                <Button Grid.Column="2"
                                        Content="New Copy"
                                        MinWidth="94"
                                        Height="30"
                                        Click="NewProfileButton_OnClick" />
                            </Grid>

                            <WrapPanel Margin="0,14,0,0">
                                <Button Content="Save"
                                        MinWidth="76"
                                        Height="30"
                                        Margin="0,0,8,8"
                                        Click="SaveProfileButton_OnClick" />
                                <Button Content="Import"
                                        MinWidth="76"
                                        Height="30"
                                        Margin="0,0,8,8"
                                        Click="ImportProfileButton_OnClick" />
                                <Button Content="Export"
                                        MinWidth="76"
                                        Height="30"
                                        Margin="0,0,8,8"
                                        Click="ExportProfileButton_OnClick" />
                                <Button Content="Refresh Devices"
                                        MinWidth="116"
                                        Height="30"
                                        Margin="0,0,8,8"
                                        Click="RefreshDevicesButton_OnClick" />
                            </WrapPanel>

                            <TextBlock x:Name="ProfileStatusText"
                                       Foreground="#D5E1EA"
                                       FontSize="12"
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            BorderBrush="#26313C"
                            BorderThickness="1"
                            Background="#111820"
                            CornerRadius="4"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Devices"
                                       Foreground="#F2F6FA"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Grid.Row="1"
                                       Text="Use this list to confirm the app sees your keyboard, mouse, and HID devices before capturing binds."
                                       Foreground="#9FB0BE"
                                       FontSize="12"
                                       Margin="0,8,0,10"
                                       TextWrapping="Wrap" />
                            <ScrollViewer Grid.Row="2"
                                          VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="DevicesText"
                                           Foreground="#D5E1EA"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Bindings">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border BorderBrush="#26313C"
                            BorderThickness="1"
                            Background="#111820"
                            CornerRadius="4"
                            Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                            <TextBlock Text="Action"
                                           Foreground="#F2F6FA"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                                <ComboBox x:Name="BindingSourceComboBox"
                                          MinHeight="30"
                                          Margin="0,8,0,0"
                                          DisplayMemberPath="DisplayName"
                                          SelectionChanged="BindingSourceComboBox_OnSelectionChanged" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                            <TextBlock Text="Current input"
                                           Foreground="#F2F6FA"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="SelectedBindingText"
                                           Foreground="#D5E1EA"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           Margin="0,11,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Button Grid.Column="4"
                                    x:Name="CaptureSelectedBindingButton"
                                    Content="Capture"
                                    Width="112"
                                    Height="32"
                                    Margin="0,22,0,0"
                                    Click="CaptureSelectedBindingButton_OnClick" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            BorderBrush="#26313C"
                            BorderThickness="1"
                            Background="#111820"
                            CornerRadius="4"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Action bindings"
                                       Foreground="#F2F6FA"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <DataGrid Grid.Row="1"
                                      x:Name="InputSourcesGrid"
                                      Margin="0,12,0,0"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      Background="#111820"
                                      Foreground="#F2F6FA"
                                      RowBackground="#111820"
                                      AlternatingRowBackground="#151E27"
                                      BorderBrush="#26313C">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name"
                                                        Binding="{Binding DisplayName}"
                                                        Width="2*" />
                                    <DataGridTextColumn Header="Kind"
                                                        Binding="{Binding Kind}"
                                                        Width="*" />
                                    <DataGridTextColumn Header="Binding"
                                                        Binding="{Binding BindingText}"
                                                        Width="3*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Diagnostics">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="StatusText"
                               Foreground="#D5E1EA"
                               FontSize="13"
                               TextWrapping="Wrap" />

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border BorderBrush="#26313C"
                                BorderThickness="1"
                                Background="#111820"
                                CornerRadius="4"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="Raw snapshot"
                                           Foreground="#F2F6FA"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="RawSnapshotText"
                                           Foreground="#D5E1EA"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                BorderBrush="#26313C"
                                BorderThickness="1"
                                Background="#111820"
                                CornerRadius="4"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="Profile values"
                                           Foreground="#F2F6FA"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="ProfileValuesText"
                                           Foreground="#D5E1EA"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="3"
                   x:Name="FooterStatusText"
                   Foreground="#9FB0BE"
                   FontSize="12"
                   Margin="0,12,0,0"
                   TextWrapping="Wrap" />
    </Grid>
</Window>
