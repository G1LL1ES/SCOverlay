    <ProjectReference Include="..\SCOverlay.BrowserSource\SCOverlay.BrowserSource.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <AssemblyName>SCOverlay</AssemblyName>
    <Product>SC Overlay</Product>
    <Company>SC Overlay</Company>
