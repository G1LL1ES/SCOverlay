<Window x:Class="SCOverlay.App.InstanceConflictWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SC Overlay is already running"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#101418">
    <Border Padding="22"
            Width="430">
        <StackPanel>
            <TextBlock Text="SC Overlay is already running"
                       Foreground="#F2F6FA"
                       FontSize="20"
                       FontWeight="SemiBold" />
            <TextBlock Text="Choose how this launch should continue."
                       Foreground="#AAB7C4"
                       FontSize="13"
                       Margin="0,8,0,18"
                       TextWrapping="Wrap" />

            <Button Content="Focus Existing"
                    Height="34"
                    Margin="0,0,0,8"
                    Click="FocusExistingButton_OnClick" />
            <Button Content="Start Another"
                    Height="34"
                    Margin="0,0,0,8"
                    Click="StartAnotherButton_OnClick" />
            <Button Content="Quit Old And Start"
                    Height="34"
                    Click="QuitOldButton_OnClick" />
        </StackPanel>
    </Border>
</Window>
