<Window x:Class="SCOverlay.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SC Overlay"
        MinHeight="560"
        MinWidth="900"
        Height="720"
        Width="1180"
        Background="#101418">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="SC Overlay"
                           Foreground="#F2F6FA"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="HeaderText"
                           Foreground="#AAB7C4"
                           FontSize="14"
                           Margin="0,5,0,0"
                           TextWrapping="Wrap" />
            </StackPanel>

            <TextBlock Grid.Column="1"
                       x:Name="ObsUrlText"
                       Foreground="#C7D6E2"
                       FontSize="12"
                       Margin="24,8,0,0"
                       TextAlignment="Right"
                       TextWrapping="Wrap" />
        </Grid>

        <TabControl Grid.Row="2"
                    Background="#161D24"
                    BorderBrush="#2A3440"
                    Foreground="#F2F6FA">
            <TabItem Header="Setup">
                <Grid Margin="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border BorderBrush="#26313C"
                            BorderThickness="1"
                            Background="#111820"
                            CornerRadius="4"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Profiles"
                                       Foreground="#F2F6FA"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Active profile"
                                       Foreground="#9FB0BE"
                                       FontSize="12"
                                       Margin="0,14,0,5" />
                            <ComboBox x:Name="ProfileComboBox"
                                      MinHeight="30"
                                      DisplayMemberPath="Name"
                                      SelectionChanged="ProfileComboBox_OnSelectionChanged" />

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="NewProfileNameTextBox"
                                         MinHeight="30"
                                         VerticalContentAlignment="Center" />
                                <Button Grid.Column="2"
                                        Content="New Copy"
                                        MinWidth="94"
                                        Height="30"
                                        Click="NewProfileButton_OnClick" />
                            </Grid>

                            <WrapPanel Margin="0,14,0,0">
                                <Button Content="Save"
                                        MinWidth="76"
                                        Height="30"
                                        Margin="0,0,8,8"
                                        Click="SaveProfileButton_OnClick" />
                                <Button Content="Import"
                                        MinWidth="76"
                                        Height="30"
                                        Margin="0,0,8,8"
                                        Click="ImportProfileButton_OnClick" />
                                <Button Content="Export"
                                        MinWidth="76"
                                        Height="30"
                                        Margin="0,0,8,8"
                                        Click="ExportProfileButton_OnClick" />
                                <Button Content="Refresh Devices"
                                        MinWidth="116"
                                        Height="30"
                                        Margin="0,0,8,8"
                                        Click="RefreshDevicesButton_OnClick" />
                            </WrapPanel>

                            <TextBlock x:Name="ProfileStatusText"
                                       Foreground="#D5E1EA"
                                       FontSize="12"
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap" />

                            <TextBlock Text="Desktop overlay"
                                       Foreground="#F2F6FA"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,24,0,0" />
                            <WrapPanel Margin="0,12,0,0">
                                <CheckBox x:Name="DesktopOverlayVisibleCheckBox"
                                          Content="Show"
                                          Foreground="#D5E1EA"
                                          Margin="0,0,16,8"
                                          Checked="DesktopOverlayVisibleCheckBox_OnChanged"
                                          Unchecked="DesktopOverlayVisibleCheckBox_OnChanged" />
                                <CheckBox x:Name="DesktopOverlayLockedCheckBox"
                                          Content="Locked"
                                          Foreground="#D5E1EA"
                                          Margin="0,0,16,8"
                                          Checked="DesktopOverlayLockedCheckBox_OnChanged"
                                          Unchecked="DesktopOverlayLockedCheckBox_OnChanged" />
                                <CheckBox x:Name="DesktopOverlayClickThroughCheckBox"
                                          Content="Click-through"
                                          Foreground="#D5E1EA"
                                          Margin="0,0,16,8"
                                          Checked="DesktopOverlayClickThroughCheckBox_OnChanged"
                                          Unchecked="DesktopOverlayClickThroughCheckBox_OnChanged" />
                            </WrapPanel>
                            <WrapPanel Margin="0,6,0,0">
                                <Button Content="Reset Position"
                                        MinWidth="116"
                                        Height="30"
                                        Margin="0,0,8,8"
                                        Click="ResetDesktopOverlayButton_OnClick" />
                            </WrapPanel>
                            <TextBlock x:Name="DesktopOverlayStatusText"
                                       Foreground="#9FB0BE"
                                       FontSize="12"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            BorderBrush="#26313C"
                            BorderThickness="1"
                            Background="#111820"
                            CornerRadius="4"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Devices"
                                       Foreground="#F2F6FA"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Grid.Row="1"
                                       Text="Use this list to confirm the app sees your keyboard, mouse, and HID devices before capturing binds."
                                       Foreground="#9FB0BE"
                                       FontSize="12"
                                       Margin="0,8,0,10"
                                       TextWrapping="Wrap" />
                            <ScrollViewer Grid.Row="2"
                                          VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="DevicesText"
                                           Foreground="#D5E1EA"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Bindings">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border BorderBrush="#26313C"
                            BorderThickness="1"
                            Background="#111820"
                            CornerRadius="4"
                            Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                            <TextBlock Text="Action"
                                           Foreground="#F2F6FA"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                                <ComboBox x:Name="BindingSourceComboBox"
                                          MinHeight="30"
                                          Margin="0,8,0,0"
                                          DisplayMemberPath="DisplayName"
                                          SelectionChanged="BindingSourceComboBox_OnSelectionChanged" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                            <TextBlock Text="Current input"
                                           Foreground="#F2F6FA"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="SelectedBindingText"
                                           Foreground="#D5E1EA"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           Margin="0,11,0,0"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="Physical binding"
                                           Foreground="#9FB0BE"
                                           FontSize="12"
                                           Margin="0,12,0,5" />
                                <ComboBox x:Name="BindingDetailComboBox"
                                          MinHeight="30"
                                          DisplayMemberPath="DisplayName"
                                          SelectionChanged="BindingDetailComboBox_OnSelectionChanged" />
                                <CheckBox x:Name="BindingInvertAxisCheckBox"
                                          Content="Invert controller axis"
                                          Foreground="#D5E1EA"
                                          Margin="0,10,0,0"
                                          Visibility="Collapsed"
                                          Checked="BindingInvertAxisCheckBox_OnChanged"
                                          Unchecked="BindingInvertAxisCheckBox_OnChanged" />
                            </StackPanel>

                            <StackPanel Grid.Column="4"
                                        Margin="0,22,0,0">
                                <Button x:Name="CaptureSelectedBindingButton"
                                        Content="Capture"
                                        Width="112"
                                        Height="32"
                                        Click="CaptureSelectedBindingButton_OnClick" />
                                <Button x:Name="RemoveSelectedBindingButton"
                                        Content="Remove"
                                        Width="112"
                                        Height="32"
                                        Margin="0,8,0,0"
                                        Click="RemoveSelectedBindingButton_OnClick" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            BorderBrush="#26313C"
                            BorderThickness="1"
                            Background="#111820"
                            CornerRadius="4"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Action bindings"
                                       Foreground="#F2F6FA"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <DataGrid Grid.Row="1"
                                      x:Name="InputSourcesGrid"
                                      Margin="0,12,0,0"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      Background="#111820"
                                      Foreground="#F2F6FA"
                                      RowBackground="#111820"
                                      AlternatingRowBackground="#151E27"
                                      BorderBrush="#26313C">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name"
                                                        Binding="{Binding DisplayName}"
                                                        Width="2*" />
                                    <DataGridTextColumn Header="Kind"
                                                        Binding="{Binding Kind}"
                                                        Width="*" />
                                    <DataGridTextColumn Header="Binding"
                                                        Binding="{Binding BindingText}"
                                                        Width="3*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Appearance">
                <Grid Margin="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border BorderBrush="#26313C"
                            BorderThickness="1"
                            Background="#111820"
                            CornerRadius="4"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="HUD style"
                                       Foreground="#F2F6FA"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Preset"
                                       Foreground="#9FB0BE"
                                       FontSize="12"
                                       Margin="0,14,0,5" />
                            <ComboBox x:Name="AppearancePresetComboBox"
                                      MinHeight="30"
                                      DisplayMemberPath="Name"
                                      SelectionChanged="AppearancePresetComboBox_OnSelectionChanged" />

                            <TextBlock Text="Input primary color"
                                       Foreground="#9FB0BE"
                                       FontSize="12"
                                       Margin="0,16,0,5" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="AppearanceRingColorSwatch"
                                        Width="32"
                                        Height="30"
                                        BorderBrush="#405060"
                                        BorderThickness="1"
                                        CornerRadius="3" />
                                <TextBox Grid.Column="2"
                                         x:Name="AppearanceRingColorTextBox"
                                         MinHeight="30"
                                         VerticalContentAlignment="Center"
                                         FontFamily="Consolas"
                                         TextChanged="AppearanceColorTextBox_OnTextChanged" />
                                <Button Grid.Column="4"
                                        Content="Pick"
                                        MinWidth="56"
                                        Height="30"
                                        Click="PickPrimaryColorButton_OnClick" />
                            </Grid>

                            <TextBlock Text="Input active color"
                                       Foreground="#9FB0BE"
                                       FontSize="12"
                                       Margin="0,12,0,5" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="AppearanceActiveColorSwatch"
                                        Width="32"
                                        Height="30"
                                        BorderBrush="#405060"
                                        BorderThickness="1"
                                        CornerRadius="3" />
                                <TextBox Grid.Column="2"
                                         x:Name="AppearanceActiveColorTextBox"
                                         MinHeight="30"
                                         VerticalContentAlignment="Center"
                                         FontFamily="Consolas"
                                         TextChanged="AppearanceColorTextBox_OnTextChanged" />
                                <Button Grid.Column="4"
                                        Content="Pick"
                                        MinWidth="56"
                                        Height="30"
                                        Click="PickActiveColorButton_OnClick" />
                            </Grid>

                            <TextBlock Text="Frame primary color"
                                       Foreground="#9FB0BE"
                                       FontSize="12"
                                       Margin="0,12,0,5" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="AppearanceFrameColorSwatch"
                                        Width="32"
                                        Height="30"
                                        BorderBrush="#405060"
                                        BorderThickness="1"
                                        CornerRadius="3" />
                                <TextBox Grid.Column="2"
                                         x:Name="AppearanceFrameColorTextBox"
                                         MinHeight="30"
                                         VerticalContentAlignment="Center"
                                         FontFamily="Consolas"
                                         TextChanged="AppearanceColorTextBox_OnTextChanged" />
                                <Button Grid.Column="4"
                                        Content="Pick"
                                        MinWidth="56"
                                        Height="30"
                                        Click="PickFramePrimaryColorButton_OnClick" />
                            </Grid>

                            <TextBlock Text="Frame active color"
                                       Foreground="#9FB0BE"
                                       FontSize="12"
                                       Margin="0,12,0,5" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="AppearanceFrameActiveColorSwatch"
                                        Width="32"
                                        Height="30"
                                        BorderBrush="#405060"
                                        BorderThickness="1"
                                        CornerRadius="3" />
                                <TextBox Grid.Column="2"
                                         x:Name="AppearanceFrameActiveColorTextBox"
                                         MinHeight="30"
                                         VerticalContentAlignment="Center"
                                         FontFamily="Consolas"
                                         TextChanged="AppearanceColorTextBox_OnTextChanged" />
                                <Button Grid.Column="4"
                                        Content="Pick"
                                        MinWidth="56"
                                        Height="30"
                                        Click="PickFrameActiveColorButton_OnClick" />
                            </Grid>

                            <Border x:Name="AppearancePreviewBackplate"
                                    Background="Transparent"
                                    HorizontalAlignment="Left"
                                    Margin="0,20,0,0"
                                    CornerRadius="5">
                                <TextBlock x:Name="AppearancePreviewText"
                                           Foreground="#D5E1EA"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Text="BOOST  BRAKE" />
                            </Border>

                            <TextBlock Text="Effects"
                                       Foreground="#F2F6FA"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,20,0,0" />
                            <WrapPanel Margin="0,10,0,0">
                                <CheckBox x:Name="AppearanceOutlineCheckBox"
                                          Content="Outline"
                                          Foreground="#D5E1EA"
                                          Margin="0,0,16,8"
                                          Checked="AppearanceEffect_OnChanged"
                                          Unchecked="AppearanceEffect_OnChanged" />
                                <CheckBox x:Name="AppearanceShadowCheckBox"
                                          Content="Shadow"
                                          Foreground="#D5E1EA"
                                          Margin="0,0,16,8"
                                          Checked="AppearanceEffect_OnChanged"
                                          Unchecked="AppearanceEffect_OnChanged" />
                                <CheckBox x:Name="AppearanceBackplateCheckBox"
                                          Content="Text backplate"
                                          Foreground="#D5E1EA"
                                          Margin="0,0,16,8"
                                          Checked="AppearanceEffect_OnChanged"
                                          Unchecked="AppearanceEffect_OnChanged" />
                            </WrapPanel>

                            <WrapPanel Margin="0,18,0,0">
                                <Button Content="Apply"
                                        MinWidth="76"
                                        Height="30"
                                        Margin="0,0,8,8"
                                        Click="ApplyAppearanceButton_OnClick" />
                                <Button Content="Reset"
                                        MinWidth="76"
                                        Height="30"
                                        Margin="0,0,8,8"
                                        Click="ResetAppearanceButton_OnClick" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            BorderBrush="#26313C"
                            BorderThickness="1"
                            Background="#111820"
                            CornerRadius="4"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Sizing and opacity"
                                       Foreground="#F2F6FA"
                                       FontSize="16"
                                       FontWeight="SemiBold" />

                            <Grid Grid.Row="1"
                                  Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Scale"
                                           Foreground="#D5E1EA"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        x:Name="AppearanceScaleSlider"
                                        Minimum="0.5"
                                        Maximum="1.75"
                                        TickFrequency="0.05"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="AppearanceSlider_OnValueChanged" />
                                <TextBlock Grid.Column="2"
                                           x:Name="AppearanceScaleValueText"
                                           Foreground="#D5E1EA"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid Grid.Row="2"
                                  Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Opacity"
                                           Foreground="#D5E1EA"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        x:Name="AppearanceOpacitySlider"
                                        Minimum="0.1"
                                        Maximum="1.0"
                                        TickFrequency="0.05"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="AppearanceSlider_OnValueChanged" />
                                <TextBlock Grid.Column="2"
                                           x:Name="AppearanceOpacityValueText"
                                           Foreground="#D5E1EA"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid Grid.Row="3"
                                  Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Input primary"
                                           Foreground="#D5E1EA"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        x:Name="AppearancePrimaryOpacitySlider"
                                        Minimum="0"
                                        Maximum="1.0"
                                        TickFrequency="0.05"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="AppearanceSlider_OnValueChanged" />
                                <TextBlock Grid.Column="2"
                                           x:Name="AppearancePrimaryOpacityValueText"
                                           Foreground="#D5E1EA"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid Grid.Row="4"
                                  Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Input active"
                                           Foreground="#D5E1EA"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        x:Name="AppearanceActiveOpacitySlider"
                                        Minimum="0"
                                        Maximum="1.0"
                                        TickFrequency="0.05"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="AppearanceSlider_OnValueChanged" />
                                <TextBlock Grid.Column="2"
                                           x:Name="AppearanceActiveOpacityValueText"
                                           Foreground="#D5E1EA"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid Grid.Row="5"
                                  Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Frame primary"
                                           Foreground="#D5E1EA"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        x:Name="AppearanceFramePrimaryOpacitySlider"
                                        Minimum="0"
                                        Maximum="1.0"
                                        TickFrequency="0.05"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="AppearanceSlider_OnValueChanged" />
                                <TextBlock Grid.Column="2"
                                           x:Name="AppearanceFramePrimaryOpacityValueText"
                                           Foreground="#D5E1EA"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid Grid.Row="6"
                                  Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Frame active"
                                           Foreground="#D5E1EA"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        x:Name="AppearanceFrameActiveOpacitySlider"
                                        Minimum="0"
                                        Maximum="1.0"
                                        TickFrequency="0.05"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="AppearanceSlider_OnValueChanged" />
                                <TextBlock Grid.Column="2"
                                           x:Name="AppearanceFrameActiveOpacityValueText"
                                           Foreground="#D5E1EA"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid Grid.Row="7"
                                  Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Outline"
                                           Foreground="#D5E1EA"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        x:Name="AppearanceOutlineWidthSlider"
                                        Minimum="0"
                                        Maximum="8"
                                        TickFrequency="0.5"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="AppearanceSlider_OnValueChanged" />
                                <TextBlock Grid.Column="2"
                                           x:Name="AppearanceOutlineWidthValueText"
                                           Foreground="#D5E1EA"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid Grid.Row="8"
                                  Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Shadow"
                                           Foreground="#D5E1EA"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        x:Name="AppearanceShadowBlurSlider"
                                        Minimum="0"
                                        Maximum="20"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="AppearanceSlider_OnValueChanged" />
                                <TextBlock Grid.Column="2"
                                           x:Name="AppearanceShadowBlurValueText"
                                           Foreground="#D5E1EA"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid Grid.Row="9"
                                  Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="70" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Backplate"
                                           Foreground="#D5E1EA"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        x:Name="AppearanceBackplateOpacitySlider"
                                        Minimum="0"
                                        Maximum="0.8"
                                        TickFrequency="0.05"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="AppearanceSlider_OnValueChanged" />
                                <TextBlock Grid.Column="2"
                                           x:Name="AppearanceBackplateOpacityValueText"
                                           Foreground="#D5E1EA"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Elements">
                <Grid Margin="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <Border BorderBrush="#26313C"
                            BorderThickness="1"
                            Background="#111820"
                            CornerRadius="4"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Element"
                                       Foreground="#F2F6FA"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Widget"
                                       Foreground="#9FB0BE"
                                       FontSize="12"
                                       Margin="0,14,0,5" />
                            <ComboBox x:Name="ElementWidgetComboBox"
                                      MinHeight="30"
                                      DisplayMemberPath="DisplayName"
                                      SelectionChanged="ElementWidgetComboBox_OnSelectionChanged" />

                            <WrapPanel Margin="0,18,0,0">
                                <Button Content="Apply"
                                        MinWidth="76"
                                        Height="30"
                                        Margin="0,0,8,8"
                                        Click="ApplyElementAppearanceButton_OnClick" />
                                <Button Content="Reset"
                                        MinWidth="76"
                                        Height="30"
                                        Margin="0,0,8,8"
                                        Click="ResetElementAppearanceButton_OnClick" />
                            </WrapPanel>

                            <StackPanel x:Name="ElementRollAssetPanel"
                                        Margin="0,20,0,0">
                                <TextBlock Text="Roll display"
                                           Foreground="#9FB0BE"
                                           FontSize="12"
                                           Margin="0,0,0,5" />
                                <ComboBox x:Name="ElementRollAssetComboBox"
                                          MinHeight="30"
                                          DisplayMemberPath="DisplayName"
                                          SelectionChanged="ElementRollAssetComboBox_OnSelectionChanged" />
                            </StackPanel>

                            <CheckBox x:Name="ElementStateTextShakeCheckBox"
                                      Content="Shake when maxed"
                                      Foreground="#D5E1EA"
                                      Margin="0,20,0,0"
                                      Checked="ElementStateTextShakeCheckBox_OnChanged"
                                      Unchecked="ElementStateTextShakeCheckBox_OnChanged" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            BorderBrush="#26313C"
                            BorderThickness="1"
                            Background="#111820"
                            CornerRadius="4"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Layout"
                                       Foreground="#F2F6FA"
                                       FontSize="16"
                                       FontWeight="SemiBold" />

                            <Grid Grid.Row="1"
                                  Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="74" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="X"
                                           Foreground="#D5E1EA"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        x:Name="ElementXSlider"
                                        Minimum="-500"
                                        Maximum="500"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="ElementSlider_OnValueChanged" />
                                <TextBlock Grid.Column="2"
                                           x:Name="ElementXValueText"
                                           Foreground="#D5E1EA"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid Grid.Row="2"
                                  Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="74" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Y"
                                           Foreground="#D5E1EA"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        x:Name="ElementYSlider"
                                        Minimum="-350"
                                        Maximum="350"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="ElementSlider_OnValueChanged" />
                                <TextBlock Grid.Column="2"
                                           x:Name="ElementYValueText"
                                           Foreground="#D5E1EA"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid Grid.Row="3"
                                  Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="74" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Scale"
                                           Foreground="#D5E1EA"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        x:Name="ElementScaleSlider"
                                        Minimum="0.25"
                                        Maximum="3"
                                        TickFrequency="0.05"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="ElementSlider_OnValueChanged" />
                                <TextBlock Grid.Column="2"
                                           x:Name="ElementScaleValueText"
                                           Foreground="#D5E1EA"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid Grid.Row="4"
                                  Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="74" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Opacity"
                                           Foreground="#D5E1EA"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        x:Name="ElementOpacitySlider"
                                        Minimum="0"
                                        Maximum="1"
                                        TickFrequency="0.05"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="ElementSlider_OnValueChanged" />
                                <TextBlock Grid.Column="2"
                                           x:Name="ElementOpacityValueText"
                                           Foreground="#D5E1EA"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <TextBlock Grid.Row="5"
                                       Text="Components"
                                       Foreground="#F2F6FA"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,24,0,0" />

                            <Grid Grid.Row="6"
                                  Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="74" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Line"
                                           Foreground="#D5E1EA"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        x:Name="ElementLineThicknessSlider"
                                        Minimum="0"
                                        Maximum="20"
                                        TickFrequency="0.5"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="ElementSlider_OnValueChanged" />
                                <TextBlock Grid.Column="2"
                                           x:Name="ElementLineThicknessValueText"
                                           Foreground="#D5E1EA"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid Grid.Row="7"
                                  x:Name="ElementThrottleCornerRow"
                                  Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="74" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Corners"
                                           Foreground="#D5E1EA"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        x:Name="ElementThrottleCornerSlider"
                                        Minimum="0"
                                        Maximum="40"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="ElementSlider_OnValueChanged" />
                                <TextBlock Grid.Column="2"
                                           x:Name="ElementThrottleCornerValueText"
                                           Foreground="#D5E1EA"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid Grid.Row="8"
                                  x:Name="ElementRollRotationRow"
                                  Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="74" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Roll max"
                                           Foreground="#D5E1EA"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Column="1"
                                        x:Name="ElementRollMaxRotationSlider"
                                        Minimum="5"
                                        Maximum="180"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True"
                                        ValueChanged="ElementSlider_OnValueChanged" />
                                <TextBlock Grid.Column="2"
                                           x:Name="ElementRollMaxRotationValueText"
                                           Foreground="#D5E1EA"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Diagnostics">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="StatusText"
                               Foreground="#D5E1EA"
                               FontSize="13"
                               TextWrapping="Wrap" />

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border BorderBrush="#26313C"
                                BorderThickness="1"
                                Background="#111820"
                                CornerRadius="4"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="Raw snapshot"
                                           Foreground="#F2F6FA"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="RawSnapshotText"
                                           Foreground="#D5E1EA"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                BorderBrush="#26313C"
                                BorderThickness="1"
                                Background="#111820"
                                CornerRadius="4"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="Profile values"
                                           Foreground="#F2F6FA"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                                <TextBlock x:Name="ProfileValuesText"
                                           Foreground="#D5E1EA"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="3"
                   x:Name="FooterStatusText"
                   Foreground="#9FB0BE"
                   FontSize="12"
                   Margin="0,12,0,0"
                   TextWrapping="Wrap" />
    </Grid>
</Window>
